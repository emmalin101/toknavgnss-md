# Required for admin session signing. Use a long random value in production.
CMS_SESSION_SECRET="replace-with-a-long-random-secret"

# Storage mode:
# - local: writes content/cms-data.json, content/cms-auth.json and public/uploads locally.
# - github: writes those files back to the GitHub repository, then Vercel can redeploy.
CMS_STORAGE_MODE="local"

# Required when CMS_STORAGE_MODE=github.
CMS_GITHUB_TOKEN=""
CMS_GITHUB_REPO="emmalin101/toknavgnss-md"
CMS_GITHUB_BRANCH="main"

# Optional first admin via env. You can also initialize from /admin/login.
CMS_ADMIN_EMAIL="your-admin@example.com"
CMS_ADMIN_PASSWORD_HASH=""

# Upload limits.
CMS_MAX_UPLOAD_MB="5"

# Existing inquiry email settings.
RESEND_API_KEY=""
INQUIRY_TO_EMAIL="info@toknavgnss.md,sales@toknavgnss.md"
INQUIRY_FROM_EMAIL="TOKNAV Website <onboarding@resend.dev>"
