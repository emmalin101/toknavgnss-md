16:Tc68,{"@context":"https://schema.org","@type":"Product","name":"Tboat USV Series","brand":{"@type":"Brand","name":"TOKNAV"},"category":"GNSS Application Solutions","image":"/assets/products/tboat20.webp","description":"Tboat10 and Tboat20 unmanned surface vehicles for bathymetric survey, water quality monitoring, patrol and hydrographic operations.","manufacturer":{"@type":"Organization","name":"Guangzhou Toksurvey Information Technology Co., Ltd."},"additionalProperty":[{"@type":"PropertyValue","name":"Models","value":"Tboat10 for compact unmanned surface operations; Tboat20 for full-function professional USV projects"},{"@type":"PropertyValue","name":"Application scenarios","value":"Bathymetric survey, water quality monitoring, water quality sampling, patrol USV with side-scan sonar, hydrological monitoring and underwater surveying"},{"@type":"PropertyValue","name":"Payload","value":"Tboat10 maximum payload 35kg; Tboat20 maximum payload 50kg"},{"@type":"PropertyValue","name":"Hull protection","value":"IP67 waterproof and dustproof hull design with reinforced bumper protection"},{"@type":"PropertyValue","name":"Tboat10 hull dimensions","value":"980 x 520 x 254mm; draft 8.5cm; hull 7kg, total weight 30kg"},{"@type":"PropertyValue","name":"Tboat20 hull dimensions","value":"1280 x 580 x 430mm; draft 10cm; hull 12kg, total weight 40kg"},{"@type":"PropertyValue","name":"Battery","value":"33.6V 25Ah x 2 rechargeable ternary lithium battery packs with hot-swap replacement"},{"@type":"PropertyValue","name":"Operating time","value":"3 hours at 2m/s; up to 7 hours at 1.5m/s"},{"@type":"PropertyValue","name":"Maximum speed","value":"Tboat10 up to 7m/s and supports safe passage through 4m/s current cross-sections; Tboat20 up to 6m/s"},{"@type":"PropertyValue","name":"Motor","value":"Brushless dual motors; Tboat10 rated 900W, Tboat20 rated 1100W"},{"@type":"PropertyValue","name":"GNSS","value":"Built-in GNSS positioning and orientation dual antenna with BDS, GPS, GLONASS, Galileo, QZSS and SBAS signal support"},{"@type":"PropertyValue","name":"RTK positioning accuracy","value":"Horizontal +/-8mm + 1ppm; vertical +/-15mm + 1ppm"},{"@type":"PropertyValue","name":"Directional accuracy","value":"0.1 degree accuracy with 1m baseline"},{"@type":"PropertyValue","name":"Control modes","value":"Manual, automatic, hover and return-to-home modes"},{"@type":"PropertyValue","name":"Communication","value":"4G and 2.4G data/video communication; optional base station radio and network CORS"},{"@type":"PropertyValue","name":"Interfaces","value":"2 x RJ45 Ethernet ports, 2 x RS232 serial ports, 2 x RS485 serial ports"},{"@type":"PropertyValue","name":"Depth frequency","value":"200kHz single-beam depth measurement listed in series brochure"},{"@type":"PropertyValue","name":"Depth range","value":"0.15-200m, with extended range available as an option"},{"@type":"PropertyValue","name":"Depth accuracy","value":"+/-1cm + 0.1% D, where D is water depth"},{"@type":"PropertyValue","name":"Payload options","value":"Echo sounder, side-scan sonar, multibeam echo sounder, ADCP, in-situ analyzer, cameras, LiDAR and water quality sensors depending on configuration"}]}d:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$16"}}]
17:T419,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is Tboat USV Series mainly used for?","acceptedAnswer":{"@type":"Answer","text":"Tboat USV Series is mainly used for Bathymetric survey, Water quality monitoring, Patrol USV with side-scan sonar, Hydrological monitoring. Buyers can confirm the final configuration based on project application, country, correction method and accessory requirements."}},{"@type":"Question","name":"Can I request the latest datasheet and price for Tboat USV Series?","acceptedAnswer":{"@type":"Answer","text":"Yes. Use the quote form on this page to request the latest datasheet, price, MOQ, lead time, packing list and recommended accessories for Tboat USV Series."}},{"@type":"Question","name":"Are the parameters final for every market?","acceptedAnswer":{"@type":"Answer","text":"Product parameters may be updated by the manufacturer and can vary by configuration or regional version. TOKNAV should confirm the latest configuration before quotation or shipment."}}]}e:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$17"}}]
