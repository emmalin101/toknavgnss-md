17:Tc42,{"@context":"https://schema.org","@type":"Product","name":"TR10Pro Line Marking Robot","brand":{"@type":"Brand","name":"TOKNAV"},"category":"GNSS Application Solutions","image":"/uploads/2026/06/field-marking-white-full-1782268936782.jpg","description":"RTK-guided line marking robot for sports fields, highways, municipal roads, airport runways and pre-marking workflows.","manufacturer":{"@type":"Organization","name":"Guangzhou Toksurvey Information Technology Co., Ltd."},"additionalProperty":[{"@type":"PropertyValue","name":"GNSS positioning","value":"Full-constellation RTK positioning with 1408 channels"},{"@type":"PropertyValue","name":"Supported constellations","value":"BDS, GPS, GLONASS, Galileo, SBAS and QZSS listed in the latest TR10 series brochure"},{"@type":"PropertyValue","name":"File import","value":"DXF, CSV and other design file formats supported by the app"},{"@type":"PropertyValue","name":"Templates","value":"Built-in sports field models, icons, arrows and numbers, with user-defined editing and template import"},{"@type":"PropertyValue","name":"Workflow","value":"Import design file, calculation, task scheduling, route planning, measuring and locating, automatic marking and report output"},{"@type":"PropertyValue","name":"Marking accuracy","value":"+/-1.5cm listed in the latest TR10 series brochure"},{"@type":"PropertyValue","name":"Line types","value":"Dots, lines, curves, numbers, letters and patterns"},{"@type":"PropertyValue","name":"Drawing width","value":"5cm-15cm adjustable side nozzle"},{"@type":"PropertyValue","name":"Material","value":"Latex paint / titanium white slurry"},{"@type":"PropertyValue","name":"Hopper capacity","value":"10L"},{"@type":"PropertyValue","name":"Operating speed","value":"Maximum speed 1m/s; mobility speed listed as 2.6km/h"},{"@type":"PropertyValue","name":"Productivity","value":"Brochure describes the workflow as 3 times faster than manual work"},{"@type":"PropertyValue","name":"Dimensions","value":"TR10Pro: 525 x 746 x 527mm, with removable side scribing mechanism width of 243mm; TR10: 558 x 610 x 527mm"},{"@type":"PropertyValue","name":"Weight","value":"TR10: 36kg; TR10Pro: 39.3kg"},{"@type":"PropertyValue","name":"Motor","value":"400W x 2 hub motors"},{"@type":"PropertyValue","name":"Turning radius","value":"0-degree turn in place"},{"@type":"PropertyValue","name":"Climbing ability","value":"20 degrees"},{"@type":"PropertyValue","name":"Wheelbase / wheel track","value":"400mm wheelbase, 465mm wheel track"},{"@type":"PropertyValue","name":"Controller","value":"Android tablet control"},{"@type":"PropertyValue","name":"Battery","value":"TR10: 48V / 15Ah lithium; TR10Pro: 48V / 7.5Ah lithium"},{"@type":"PropertyValue","name":"Battery life","value":"8 hours listed in the brochure"},{"@type":"PropertyValue","name":"Endurance","value":"Up to 30km listed in the brochure; customized battery capacity supported"},{"@type":"PropertyValue","name":"Communication","value":"CAN"},{"@type":"PropertyValue","name":"IP rating","value":"IP3X"},{"@type":"PropertyValue","name":"Temperature","value":"Operating -10°C to 60°C; storage -10°C to 45°C"}]}d:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$17"}}]
18:T434,{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"What is TR10Pro Line Marking Robot mainly used for?","acceptedAnswer":{"@type":"Answer","text":"TR10Pro Line Marking Robot is mainly used for Sports field marking, Highway pre-marking, Municipal road marking, Airport runway marking. Buyers can confirm the final configuration based on project application, country, correction method and accessory requirements."}},{"@type":"Question","name":"Can I request the latest datasheet and price for TR10Pro Line Marking Robot?","acceptedAnswer":{"@type":"Answer","text":"Yes. Use the quote form on this page to request the latest datasheet, price, MOQ, lead time, packing list and recommended accessories for TR10Pro Line Marking Robot."}},{"@type":"Question","name":"Are the parameters final for every market?","acceptedAnswer":{"@type":"Answer","text":"Product parameters may be updated by the manufacturer and can vary by configuration or regional version. TOKNAV should confirm the latest configuration before quotation or shipment."}}]}e:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$18"}}]
