16:T83a,{"@context":"https://schema.org","@type":"Product","name":"tSurvey","brand":{"@type":"Brand","name":"TOKNAV"},"category":"Software","image":"/assets/products/tsurvey.png","description":"Android field surveying software for RTK measurement, point collection, stakeout and construction survey workflows.","manufacturer":{"@type":"Organization","name":"Guangzhou Toksurvey Information Technology Co., Ltd."},"additionalProperty":[{"@type":"PropertyValue","name":"Platform","value":"Android field surveying software for TOKNAV GNSS receiver and controller workflows"},{"@type":"PropertyValue","name":"Project setup","value":"Create field projects, manage survey points and prepare coordinate workflow before site work"},{"@type":"PropertyValue","name":"Receiver connection","value":"Connect GNSS receivers for RTK survey, base-rover operation and field data collection"},{"@type":"PropertyValue","name":"Field collection","value":"Point collection, line work, map-assisted measurement and export-ready field records"},{"@type":"PropertyValue","name":"Stakeout","value":"Point, line and construction stakeout workflows for daily survey and site layout"},{"@type":"PropertyValue","name":"Coordinate workflow","value":"Coordinate systems, projection methods and conversion preparation for project requirements"},{"@type":"PropertyValue","name":"Data exchange","value":"Import and export field data for office processing, design files and project handover"},{"@type":"PropertyValue","name":"Buyer fit","value":"Survey crews, construction teams, equipment dealers and system integrators"},{"@type":"PropertyValue","name":"tSurvey","value":"Android engineering survey software for practical RTK field measurement"},{"@type":"PropertyValue","name":"tSurvey 2.0","value":"Upgraded multilingual interface with richer survey workflow support for global field teams"},{"@type":"PropertyValue","name":"Training","value":"Suitable for dealer demonstrations, controller bundle sales and customer onboarding"},{