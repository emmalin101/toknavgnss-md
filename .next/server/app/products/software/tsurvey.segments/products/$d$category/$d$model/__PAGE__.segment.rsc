e:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is tSurvey mainly used for?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"tSurvey is mainly used for RTK field survey, Point and line stakeout, Construction layout, Controller data collection. Buyers can confirm the final configuration based on project application, country, correction method and accessory requirements.\"}},{\"@type\":\"Question\",\"name\":\"Can I request the latest datasheet and price for tSurvey?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Use the quote form on this page to request the latest datasheet, price, MOQ, lead time, packing list and recommended accessories for tSurvey.\"}},{\"@type\":\"Question\",\"name\":\"Are the parameters final for every market?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Product parameters may be updated by the manufacturer and can vary by configuration or regional version. TOKNAV should confirm the latest configuration before quotation or shipment.\"}}]}"}}]
