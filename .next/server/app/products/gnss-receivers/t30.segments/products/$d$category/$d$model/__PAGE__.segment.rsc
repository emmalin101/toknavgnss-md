16:Tb20,{"@context":"https://schema.org","@type":"Product","name":"T30 GNSS Receiver","brand":{"@type":"Brand","name":"TOKNAV"},"category":"GNSS Receivers","image":"/assets/products/t30.webp","description":"High-precision RTK receiver with Bluetooth, Wi-Fi and 410-470MHz radio support.","manufacturer":{"@type":"Organization","name":"Guangzhou Toksurvey Information Technology Co., Ltd."},"additionalProperty":[{"@type":"PropertyValue","name":"GNSS signals","value":"GPS L1C/A, L1C, L2P(Y), L2C, L5; GLONASS L1/L2/L3; BDS B1I/B2I/B3I/B1C/B2a/B2b(PPP); Galileo E1/E5a/E5b/E6(PPP); QZSS L1/L2/L5; SBAS L1(PPP); NavIC L5 on supported firmware."},{"@type":"PropertyValue","name":"Channels / output","value":"1408 channels, NMEA-0183 output and RTCM 3.x correction I/O"},{"@type":"PropertyValue","name":"Update frequency","value":"20Hz max"},{"@type":"PropertyValue","name":"RTK accuracy","value":"Horizontal +/- (8mm+1ppm), Vertical +/- (15mm+1ppm)"},{"@type":"PropertyValue","name":"Tilt correction","value":"<2cm within 60 degrees"},{"@type":"PropertyValue","name":"AR stakeout accuracy","value":"Horizontal +/- (8mm+1ppm), Vertical +/- (15mm+1ppm) on T40/T40Pro"},{"@type":"PropertyValue","name":"Photogrammetry","value":"T30Pro/T40Pro include image survey or photogrammetry support"},{"@type":"PropertyValue","name":"Laser measurement","value":"T30 laser within 5m; T40 laser module range up to 30m"},{"@type":"PropertyValue","name":"AR camera","value":"1/2.8-inch sensor, f/2.5 aperture, 1920 x 1080 resolution on listed visual models"},{"@type":"PropertyValue","name":"Image survey camera","value":"T30Pro/T40Pro use 1/2.6-inch image survey camera, f/2.8 aperture, 1920 x 1080 resolution"},{"@type":"PropertyValue","name":"Laser assist camera","value":"T30/T40 use 1/3.06-inch laser assist camera, 4224 x 3200 resolution"},{"@type":"PropertyValue","name":"Radio","value":"410-470MHz high-power transceiver; T30/T40 family supports up to 5W on selected models"},{"@type":"PropertyValue","name":"Network","value":"LTE FDD, LTE TDD, WCDMA and GSM full Netcom bands depending on market version"},{"@type":"PropertyValue","name":"Storage","value":"32GB storage"},{"@type":"PropertyValue","name":"Battery","value":"T30/T30Pro: 7.2V 13800mAh; T40/T40Pro: 7.2V 3400mAh x 2 removable batteries"},{"@type":"PropertyValue","name":"Endurance","value":"T30/T30Pro over 48 hours in controller network mode; T40/T40Pro over 20 hours in controller network mode"},{"@type":"PropertyValue","name":"Operating temperature","value":"-20°C to +60°C"},{"@type":"PropertyValue","name":"Protection","value":"IP68"},{"@type":"PropertyValue","name":"Drop resistance","value":"Can withstand a 1.5m drop at normal temperature"},{"@type":"PropertyValue","name":"Dimensions / weight","value":"T30/T30Pro Phi174.9 x 104.9mm, 1500g; T40/T40Pro Phi160 x 103mm, 850g without battery"}]}d:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$16"}}]
e:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is T30 GNSS Receiver mainly used for?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"T30 GNSS Receiver is mainly used for Surveying, Mapping, Construction. Buyers can confirm the final configuration based on project application, country, correction method and accessory requirements.\"}},{\"@type\":\"Question\",\"name\":\"Can I request the latest datasheet and price for T30 GNSS Receiver?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Use the quote form on this page to request the latest datasheet, price, MOQ, lead time, packing list and recommended accessories for T30 GNSS Receiver.\"}},{\"@type\":\"Question\",\"name\":\"Are the parameters final for every market?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Product parameters may be updated by the manufacturer and can vary by configuration or regional version. TOKNAV should confirm the latest configuration before quotation or shipment.\"}}]}"}}]
