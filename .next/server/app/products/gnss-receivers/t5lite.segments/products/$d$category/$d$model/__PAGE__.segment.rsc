16:Tc23,{"@context":"https://schema.org","@type":"Product","name":"T5Lite GNSS Receiver","brand":{"@type":"Brand","name":"TOKNAV"},"category":"GNSS Receivers","image":"/uploads/2026/06/snipaste-2025-08-08-09-49-56-1782179073624.jpg","description":"Compact GNSS RTK receiver for cost-sensitive surveying and mapping projects.","manufacturer":{"@type":"Organization","name":"Guangzhou Toksurvey Information Technology Co., Ltd."},"additionalProperty":[{"@type":"PropertyValue","name":"GNSS signals","value":"GPS L1C/A, L1C, L2P(Y), L2C, L5; GLONASS L1/L2/L3; BDS B1I/B2I/B3I/B1C/B2a/B2b(PPP); Galileo E1/E5a/E5b/E6(PPP); QZSS L1/L2/L5; SBAS L1(PPP); NavIC L5 on supported firmware."},{"@type":"PropertyValue","name":"Channels","value":"1408"},{"@type":"PropertyValue","name":"Standard output","value":"NMEA-0183"},{"@type":"PropertyValue","name":"Correction protocol","value":"RTCM 3.x, with RTCM 2.x also listed for T10Pro"},{"@type":"PropertyValue","name":"Single point accuracy","value":"Horizontal 1.5m RMS / Vertical 2.5m RMS"},{"@type":"PropertyValue","name":"DGPS accuracy","value":"Horizontal 0.4m RMS / Vertical 0.8m RMS"},{"@type":"PropertyValue","name":"RTK accuracy","value":"Horizontal +/- (8mm+1ppm), Vertical +/- (15mm+1ppm)"},{"@type":"PropertyValue","name":"Static accuracy","value":"Horizontal +/- (2.5mm+1ppm), Vertical +/- (5mm+1ppm); selected models list +/- (2.5mm+0.5ppm) / +/- (5mm+0.5ppm)"},{"@type":"PropertyValue","name":"Speed accuracy","value":"0.03m/s RMS"},{"@type":"PropertyValue","name":"Reacquisition","value":"<1s"},{"@type":"PropertyValue","name":"Platform","value":"ARM Cortex-A7 with Linux OS"},{"@type":"PropertyValue","name":"Bluetooth","value":"BR + EDR + BLE"},{"@type":"PropertyValue","name":"Wi-Fi","value":"802.11 b/g/n"},{"@type":"PropertyValue","name":"4G network","value":"LTE FDD / LTE TDD / WCDMA / GSM bands depending on model and market version"},{"@type":"PropertyValue","name":"Storage","value":"32GB storage"},{"@type":"PropertyValue","name":"Tilt correction","value":"<2cm within 60 degrees on IMU-supported receiver models"},{"@type":"PropertyValue","name":"Data radio","value":"T5 supports receive-only 410-470MHz radio; T5Lite focuses on 4G, Bluetooth and Wi-Fi workflows"},{"@type":"PropertyValue","name":"Radio protocol","value":"TRIMTALK, TRIMMK3, SOUTH, TRANSEOT on T5"},{"@type":"PropertyValue","name":"Battery","value":"3.7V, 9600mAh"},{"@type":"PropertyValue","name":"Work time","value":"More than 16 hours typical rover GSM; static collection up to 24 hours"},{"@type":"PropertyValue","name":"Charging","value":"MTK PE+ 9V/2A and USB PD 12V/1.25A or 5V/3A fast charging support"},{"@type":"PropertyValue","name":"Operating temperature","value":"-20°C to +60°C"},{"@type":"PropertyValue","name":"Storage temperature","value":"-40°C to +85°C"},{"@type":"PropertyValue","name":"Protection","value":"IP65"},{"@type":"PropertyValue","name":"Drop resistance","value":"Can withstand a 1.5m drop at normal temperature"},{"@type":"PropertyValue","name":"Dimensions / weight","value":"T5Lite 100.5 x 100.5 x 69mm, 550✨g; T5 100.5 x 100.5 x 72mm, 630g"}]}d:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$16"}}]
e:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is T5Lite GNSS Receiver mainly used for?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"T5Lite GNSS Receiver is mainly used for Surveying, Mapping, GIS field work. Buyers can confirm the final configuration based on project application, country, correction method and accessory requirements.\"}},{\"@type\":\"Question\",\"name\":\"Can I request the latest datasheet and price for T5Lite GNSS Receiver?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Use the quote form on this page to request the latest datasheet, price, MOQ, lead time, packing list and recommended accessories for T5Lite GNSS Receiver.\"}},{\"@type\":\"Question\",\"name\":\"Are the parameters final for every market?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Product parameters may be updated by the manufacturer and can vary by configuration or regional version. TOKNAV should confirm the latest configuration before quotation or shipment.\"}}]}"}}]
