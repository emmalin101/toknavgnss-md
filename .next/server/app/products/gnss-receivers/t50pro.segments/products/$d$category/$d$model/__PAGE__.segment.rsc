16:Taf3,{"@context":"https://schema.org","@type":"Product","name":"T50Pro GNSS Receiver","brand":{"@type":"Brand","name":"TOKNAV"},"category":"GNSS Receivers","image":"/assets/products/t50pro.webp","description":"High-end T50 family receiver for photogrammetry, AR stakeout and professional surveying workflows.","manufacturer":{"@type":"Organization","name":"Guangzhou Toksurvey Information Technology Co., Ltd."},"additionalProperty":[{"@type":"PropertyValue","name":"GNSS signals","value":"GPS L1C/A, L1C, L2P(Y), L2C, L5; GLONASS L1/L2/L3; BDS B1I/B2I/B3I/B1C/B2a/B2b(PPP); Galileo E1/E5a/E5b/E6(PPP); QZSS L1/L2/L5; SBAS L1(PPP); NavIC L5 on supported firmware."},{"@type":"PropertyValue","name":"Channels / output","value":"1408 channels, NMEA-0183 output and RTCM 3.x correction I/O"},{"@type":"PropertyValue","name":"Update frequency","value":"20Hz max"},{"@type":"PropertyValue","name":"RTK accuracy","value":"Horizontal +/- (8mm+1ppm), Vertical +/- (15mm+1ppm)"},{"@type":"PropertyValue","name":"Static accuracy","value":"Horizontal +/- (2.5mm+1ppm), Vertical +/- (5mm+1ppm)"},{"@type":"PropertyValue","name":"Tilt correction","value":"<2cm within 60 degrees"},{"@type":"PropertyValue","name":"AR stakeout","value":"Supported on T50basic, T50 and T50Pro"},{"@type":"PropertyValue","name":"Laser / photogrammetry","value":"T50 includes 100m laser measurement; T50Pro includes photogrammetry with 2-4cm error within 2-15m"},{"@type":"PropertyValue","name":"AR camera","value":"1/2.8-inch sensor, f/2.5 aperture, 1920 x 1080 resolution, distortion <0.38%"},{"@type":"PropertyValue","name":"T50 laser module","value":"Class 3R, 100m range, +/-5mm +/-100 x 10-6 x D precision, 520 +/-20nm wavelength"},{"@type":"PropertyValue","name":"T50Pro image camera","value":"1/2.6-inch sensor, 3.27mm focal length, f/2.8 aperture, 1920 x 1080 resolution, FOV 83 x 72 x 51 degrees"},{"@type":"PropertyValue","name":"Radio","value":"Integrated transceiver, 410-470MHz, 0.5W/1.5W, TRIMTALK/TRIMMK3/SOUTH/TRANSEOT/SATEL/LORA"},{"@type":"PropertyValue","name":"Wireless","value":"Bluetooth BR+EDR+BLE, Wi-Fi 802.11 b/g/n, LTE FDD/TDD, WCDMA and GSM bands"},{"@type":"PropertyValue","name":"Storage","value":"32GB storage"},{"@type":"PropertyValue","name":"Battery","value":"7.4V, 6500mAh"},{"@type":"PropertyValue","name":"Work time","value":"Over 16 hours in controller network mode or typical rover GSM use depending on model"},{"@type":"PropertyValue","name":"Charging","value":"USB PD 15V/2A and 5V/3A"},{"@type":"PropertyValue","name":"Operating temperature","value":"-30°C to +65°C"},{"@type":"PropertyValue","name":"Storage temperature","value":"-40°C to +85°C"},{"@type":"PropertyValue","name":"Protection","value":"IP68"},{"@type":"PropertyValue","name":"Dimensions / weight","value":"Phi132 x 83mm, 770g"}]}d:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$16"}}]
e:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is T50Pro GNSS Receiver mainly used for?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"T50Pro GNSS Receiver is mainly used for Photogrammetry, AR stakeout, Surveying. Buyers can confirm the final configuration based on project application, country, correction method and accessory requirements.\"}},{\"@type\":\"Question\",\"name\":\"Can I request the latest datasheet and price for T50Pro GNSS Receiver?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Use the quote form on this page to request the latest datasheet, price, MOQ, lead time, packing list and recommended accessories for T50Pro GNSS Receiver.\"}},{\"@type\":\"Question\",\"name\":\"Are the parameters final for every market?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Product parameters may be updated by the manufacturer and can vary by configuration or regional version. TOKNAV should confirm the latest configuration before quotation or shipment.\"}}]}"}}]
