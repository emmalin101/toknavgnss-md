16:Tb60,{"@context":"https://schema.org","@type":"Product","name":"NET660i GNSS Receiver","brand":{"@type":"Brand","name":"TOKNAV"},"category":"GNSS Receivers","image":"/assets/products/net660i.webp","description":"Compact GNSS receiver designed for system integration, CORS and monitoring deployments.","manufacturer":{"@type":"Organization","name":"Guangzhou Toksurvey Information Technology Co., Ltd."},"additionalProperty":[{"@type":"PropertyValue","name":"Platform","value":"ARM Cortex-A7 1.8GHz with Linux OS"},{"@type":"PropertyValue","name":"GNSS signals","value":"GPS, GLONASS, BDS, Galileo, QZSS, SBAS and NavIC depending on model; NET660i-H supports dual-antenna directed positioning"},{"@type":"PropertyValue","name":"Channels","value":"1408 on NET660i / NET660i-H family"},{"@type":"PropertyValue","name":"Data format","value":"RINEX and custom data format"},{"@type":"PropertyValue","name":"Position data","value":"NMEA-0183"},{"@type":"PropertyValue","name":"Differential data","value":"RTCM 3.x"},{"@type":"PropertyValue","name":"Data update frequency","value":"1Hz, 2Hz, 5Hz, 10Hz, 20Hz"},{"@type":"PropertyValue","name":"RTK accuracy","value":"Horizontal +/- (8mm+1ppm), Vertical +/- (15mm+1ppm)"},{"@type":"PropertyValue","name":"Static accuracy","value":"Horizontal +/- (2.5mm+0.5ppm), Vertical +/- (5mm+0.5ppm)"},{"@type":"PropertyValue","name":"Timing accuracy","value":"20ns RMS"},{"@type":"PropertyValue","name":"Serial port","value":"Standard RS232, baud rates 1200 to 230400bps on NET660i family"},{"@type":"PropertyValue","name":"Network port","value":"RJ45 10/100Mbps adaptive Ethernet"},{"@type":"PropertyValue","name":"Ports","value":"Power, DATA, PPS, SIM, Ethernet, GNSS antenna and 4G antenna ports depending on model"},{"@type":"PropertyValue","name":"Storage","value":"32GB circular storage, multi-channel storage support"},{"@type":"PropertyValue","name":"Protocols","value":"Ntrip Client/Server/Caster, TCP Client/Server, FTP, HTTP/HTTPS and private network transfer"},{"@type":"PropertyValue","name":"Cloud service","value":"Reports location, network status, signal strength and satellite reception; supports remote restart, reset and upgrade"},{"@type":"PropertyValue","name":"Voltage input","value":"9-24V DC, 12V typical on NET660i family"},{"@type":"PropertyValue","name":"Power dissipation","value":"1.8W typical for NET660i, 2W typical for NET660i-H"},{"@type":"PropertyValue","name":"Operating temperature","value":"-40°C to +85°C"},{"@type":"PropertyValue","name":"Storage temperature","value":"-40°C to +85°C"},{"@type":"PropertyValue","name":"Protection","value":"IP68"},{"@type":"PropertyValue","name":"Material","value":"Magnesium alloy main body"},{"@type":"PropertyValue","name":"Dimensions / weight","value":"NET660i family 148.8 x 105 x 50.3mm, 490g"},{"@type":"PropertyValue","name":"Heading accuracy","value":"NET660i-H lists 0.2 degrees/m heading accuracy"}]}d:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$16"}}]
e:["$","script",null,{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"{\"@context\":\"https://schema.org\",\"@type\":\"FAQPage\",\"mainEntity\":[{\"@type\":\"Question\",\"name\":\"What is NET660i GNSS Receiver mainly used for?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"NET660i GNSS Receiver is mainly used for CORS, System integration, Monitoring. Buyers can confirm the final configuration based on project application, country, correction method and accessory requirements.\"}},{\"@type\":\"Question\",\"name\":\"Can I request the latest datasheet and price for NET660i GNSS Receiver?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Yes. Use the quote form on this page to request the latest datasheet, price, MOQ, lead time, packing list and recommended accessories for NET660i GNSS Receiver.\"}},{\"@type\":\"Question\",\"name\":\"Are the parameters final for every market?\",\"acceptedAnswer\":{\"@type\":\"Answer\",\"text\":\"Product parameters may be updated by the manufacturer and can vary by configuration or regional version. TOKNAV should confirm the latest configuration before quotation or shipment.\"}}]}"}}]
